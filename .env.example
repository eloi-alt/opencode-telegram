# --- Required ---
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"

# --- OpenCode Runtime ---
OPENCODE_MODE="cli"              # "api" or "cli"
OPENCODE_CLI_PATH="opencode"     # path to opencode binary (CLI mode)
OPENCODE_WORKSPACE_ROOT="/home/opencode/workspaces"
OPENCODE_DEFAULT_WORKSPACE="default"
OPENCODE_DEFAULT_SERVER="local"

# --- API mode (if OPENCODE_MODE=api) ---
# OPENCODE_BASE_URL="http://localhost:8081"
# OPENCODE_API_KEY="your_api_key"

# --- Security ---
TELEGRAM_ALLOWED_USERS=""        # comma-separated Telegram user IDs, empty = all
TELEGRAM_ALLOWED_CHATS=""        # comma-separated chat IDs, empty = all
ENABLE_ADMIN_COMMANDS="true"
ENABLE_DANGEROUS_COMMANDS="false"

# --- Server ---
PORT="8080"
APP_BASE_URL=""                  # public URL for Telegram webhook (optional)
LOG_LEVEL="INFO"

# --- Persistence ---
DATABASE_URL="sqlite+aiosqlite:///data/opencode-telegram.db"
STORAGE_PATH="./data"

# --- Session ---
SESSION_TIMEOUT_SEC="1800"
MESSAGE_MAX_LENGTH="4096"

# --- Health ---
HEALTHCHECK_INTERVAL_SEC="60"
